<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="200"
        x:Class="SubtitleDisplay.MainWindow"
        Title="实时字幕显示"
        Width="1200" Height="200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        Topmost="True">
    
    <Window.Styles>
        <Style Selector="TextBlock.speaker">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style Selector="TextBlock.content">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#757575"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- 顶部控制栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <TextBox Name="WebSocketUrlTextBox" 
                     Text="ws://localhost:10095/" 
                     Width="300"
                     Watermark="WebSocket URL"/>
            <Button Name="ConnectButton" 
                    Content="连接" 
                    Click="OnConnectClick"
                    Width="80"/>
            <Button Name="DisconnectButton" 
                    Content="断开" 
                    Click="OnDisconnectClick"
                    Width="80"
                    IsEnabled="False"/>
            <Button Name="ClearButton" 
                    Content="清空" 
                    Click="OnClearClick"
                    Width="80"/>
            <TextBlock Name="StatusTextBlock" 
                       Classes="status"
                       VerticalAlignment="Center"
                       Text="未连接"/>
        </StackPanel>

        <!-- 字幕显示区域 -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8"
                Padding="20"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <ScrollViewer Name="SubtitleScrollViewer" 
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <StackPanel Name="SubtitlePanel" Spacing="15">
                    <!-- 字幕行将动态添加到这里 -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 底部信息栏 -->
        <TextBlock Grid.Row="2" 
                   Classes="status"
                   Margin="0,10,0,0"
                   Text="提示: 连接到 WebSocket 服务器以接收实时字幕"/>
    </Grid>
</Window>
