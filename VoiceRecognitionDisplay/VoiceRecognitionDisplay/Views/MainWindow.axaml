<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VoiceRecognitionDisplay.ViewModels"
        xmlns:views="using:VoiceRecognitionDisplay.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="VoiceRecognitionDisplay.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Voice Recognition Display"
        Width="{Binding WindowWidth}"
        SizeToContent="Height"
        Topmost="True"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False">

    <Border x:Name="DraggableBorder"
            BorderBrush="White" 
            BorderThickness="2" 
            CornerRadius="{Binding WindowCornerRadius}"
            Background="{Binding BackgroundColor}"
            Padding="15">
        <Grid RowDefinitions="Auto,Auto">
            
            <!-- 顶部栏：说话人信息 + 操作按钮 -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                
                <!-- 左侧：说话人信息 -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           Spacing="10"
                           VerticalAlignment="Center">
                    <!-- 说话人图标 - 始终显示 -->
                    <Border Width="32" 
                           Height="32" 
                           CornerRadius="16"
                           Background="#444444">
                        <!-- 默认小人图标 -->
                        <TextBlock Text="👤" 
                                  FontSize="20"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- 说话人名称 -->
                    <TextBlock Text="{Binding SpeakerName}" 
                              FontFamily="{Binding FontFamily}"
                              FontSize="14"
                              FontWeight="{Binding FontWeight}"
                              FontStyle="{Binding FontStyle}"
                              Foreground="{Binding FontColor}"
                              VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 右侧：操作按钮 -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           Spacing="8"
                           VerticalAlignment="Center">
                    <!-- 分享按钮 -->
                    <Button Command="{Binding ShareCommand}" 
                           ToolTip.Tip="分享"
                           Width="32"
                           Height="32"
                           Padding="0"
                           Background="#444444"
                           Foreground="White"
                           BorderThickness="0"
                           CornerRadius="16">
                        <TextBlock Text="📤" 
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Button>
                    
                    <!-- 设置按钮 -->
                    <Button Command="{Binding OpenSettingsCommand}" 
                           ToolTip.Tip="设置"
                           Width="32"
                           Height="32"
                           Padding="0"
                           Background="#444444"
                           Foreground="White"
                           BorderThickness="0"
                           CornerRadius="16">
                        <TextBlock Text="⚙️" 
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Button>
                    
                    <!-- 关闭按钮 -->
                    <Button Command="{Binding CloseCommand}" 
                           ToolTip.Tip="关闭"
                           Width="32"
                           Height="32"
                           Padding="0"
                           Background="#666666"
                           Foreground="White"
                           BorderThickness="0"
                           CornerRadius="16">
                        <TextBlock Text="✕" 
                                  FontSize="18"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- 文本显示区域 - 横向滚动模式 -->
            <views:ScrollingSubtitleControl Grid.Row="1"
                                           x:Name="SubtitleControl"
                                           HorizontalAlignment="Stretch"
                                           ScrollingText="{Binding ScrollingText}"
                                           TranslationText="{Binding TranslationText}"
                                           RecognitionMode="{Binding RecognitionMode}"
                                           ScrollSpeed="{Binding ScrollSpeed}"
                                           MaxDisplayLines="{Binding MaxDisplayLines}"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           FontColor="{Binding FontColor}"
                                           FontWeight="{Binding FontWeight}"
                                           FontStyle="{Binding FontStyle}"/>
        </Grid>
    </Border>
</Window>
